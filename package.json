{
  "name": "@flightlesslabs/colors",
  "version": "0.3.0",
  "scripts": {
    "scss:colors-base": "sh -c \"mkdir -p dist/styles && sass src/lib/styles/colors-base.scss dist/colors-base.css\"",
    "scss:colors": "sh -c \"mkdir -p dist/styles && sass src/lib/styles/colors.scss dist/colors.css\"",
    "scss": "pnpm scss:colors-base && pnpm scss:colors",
    "dev": "vite dev",
    "docs": "vite build",
    "build": "tsdown && pnpm run scss",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "check": "pnpm run lint",
    "check:fix": "eslint . && pnpm run format",
    "storybook": "storybook dev -p 6006"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json",
    "./colors-base.css": "./dist/colors-base.css",
    "./colors.css": "./dist/colors.css"
  },
  "types": "./dist/index.d.ts",
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/sveltekit": "^10.3.5",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^22",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "mdsvex": "^0.12.7",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.3.18",
    "sass-embedded": "^1.99.0",
    "storybook": "^10.3.5",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "colors"
  ]
}
